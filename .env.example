# ===========================================
# TLOUSH V3 — Variables d'environnement
# Copiez ce fichier en .env.local et remplissez les valeurs
# ===========================================

# --- Supabase (OBLIGATOIRE) ---
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Anthropic / Claude AI (OBLIGATOIRE) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Resend — Email (OBLIGATOIRE pour digest + alertes) ---
RESEND_API_KEY=re_...

# --- Cron secret (OBLIGATOIRE pour protéger les endpoints cron/alertes) ---
CRON_SECRET=votre-secret-aleatoire

# --- Upstash Redis — Rate Limiting (OPTIONNEL, dégradation gracieuse sans) ---
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# --- PostHog — Analytics (OPTIONNEL) ---
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# --- Sentry — Monitoring (OPTIONNEL) ---
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=sntrys_...

# --- Email sender (OBLIGATOIRE pour Resend — utiliser un domaine vérifié) ---
EMAIL_FROM=noreply@tloush.com

# --- URL du site (OBLIGATOIRE, utilisée dans tous les emails + webhooks) ---
# En prod, mettre le domaine final (ex: https://tloush.com) — PAS l'URL .vercel.app
# En dev : http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://tloush.com

# --- Stripe (OBLIGATOIRE pour paiement) ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_PRICE_SOLO=price_...
STRIPE_PRICE_FAMILY=price_...
# Note: ces variables sont server-only (pas de préfixe NEXT_PUBLIC)
# Le frontend utilise NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY uniquement

# --- Vercel (automatiquement fourni par Vercel, fallback si NEXT_PUBLIC_SITE_URL absent) ---
# VERCEL_URL=votre-app.vercel.app
